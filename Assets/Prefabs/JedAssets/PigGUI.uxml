<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Label tabindex="-1" text="Label" parse-escape-sequences="true" display-tooltip-when-elided="true" name="clock" style="align-items: center; align-self: center;" />
    <ui:VisualElement name="eat_timer" style="flex-grow: 0; background-image: url(&apos;project://database/Assets/Jed/Art/Red-Circle-Transparent.png?fileID=2800000&amp;guid=3ecc46a041df91049ad972ce0017299f&amp;type=3#Red-Circle-Transparent&apos;); width: 50px; height: 50px; flex-shrink: 0; border-top-left-radius: 50%; border-top-right-radius: 50%; border-bottom-right-radius: 50%; border-bottom-left-radius: 50%; background-color: rgb(255, 0, 0);">
        <ui:VisualElement name="top-half" style="flex-grow: 1; width: 100%; height: 100%; background-color: rgb(0, 0, 255); border-top-left-radius: 50%; border-top-right-radius: 50%; border-bottom-right-radius: 50%; border-bottom-left-radius: 50%; top: auto; right: auto; align-items: auto; align-self: flex-start; justify-content: flex-start; overflow: visible;" />
        <ui:VisualElement name="right-half" style="flex-grow: 1; background-color: rgb(0, 0, 255); border-top-left-radius: 50%; border-top-right-radius: 50%; border-bottom-right-radius: 50%; border-bottom-left-radius: 50%; width: 100%; height: 100%; right: auto; align-items: flex-end; align-self: flex-end;" />
    </ui:VisualElement>
